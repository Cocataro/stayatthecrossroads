---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: 'The Crossroads Inn' },
  { href: '/enter-the-inn', label: 'Enter the Inn' },
  { href: '/stay-the-night', label: 'Stay the Night' },
  { href: '/the-ledger', label: 'The Ledger' },
  { href: '/rooms', label: 'Our Rooms' },
  { href: '/the-hearth', label: 'The Hearth' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<nav class="site-nav" aria-label="Main navigation">
  <div class="nav-inner container">
    <a href="/" class="nav-brand">
      <span class="nav-brand-text">The Crossroads Inn</span>
    </a>

    <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>

    <ul class="nav-links" role="list">
      {links.slice(1).map(link => (
        <li>
          <a
            href={link.href}
            class:list={['nav-link', { 'is-active': isActive(link.href) }]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(26, 20, 16, 0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--worn-wood);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--sp-md);
    padding-bottom: var(--sp-md);
  }

  .nav-brand {
    text-decoration: none;
    color: var(--accent);
  }

  .nav-brand-text {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: var(--sp-lg);
    margin: 0;
    padding: 0;
  }

  .nav-link {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    color: var(--text-muted);
    text-decoration: none;
    padding: var(--sp-xs) 0;
    border-bottom: 2px solid transparent;
    transition: color var(--transition), border-color var(--transition);
  }

  .nav-link:hover,
  .nav-link.is-active {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  /* ── Mobile hamburger ── */
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--sp-sm);
  }

  .nav-toggle-bar {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--accent);
    transition: transform var(--transition), opacity var(--transition);
  }

  @media (max-width: 768px) {
    .nav-toggle { display: flex; }

    .nav-links {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      background: rgba(26, 20, 16, 0.98);
      border-bottom: 1px solid var(--worn-wood);
      padding: var(--sp-lg);
      gap: var(--sp-md);
      display: none;
    }

    .nav-links.is-open { display: flex; }

    .nav-link {
      font-size: 1rem;
      padding: var(--sp-sm) 0;
    }
  }
</style>

<script>
  const toggle = document.querySelector('.nav-toggle');
  const links = document.querySelector('.nav-links');
  if (toggle && links) {
    toggle.addEventListener('click', () => {
      const isOpen = links.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', String(isOpen));
    });
  }
</script>
