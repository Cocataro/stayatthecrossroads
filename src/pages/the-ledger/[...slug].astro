---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('ledger');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const title = `${post.data.title} — The Ledger | Stay at The Crossroads`;
---

<Layout title={title} description={post.data.description}>

  <article class="section container">
    <div class="content-narrow">

      <div class="post-header">
        <a href="/the-ledger" class="back-link">&larr; Back to the Ledger</a>
        <time datetime={post.data.date.toISOString().split('T')[0]}>
          {post.data.date.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
        <h1>{post.data.title}</h1>
        {post.data.tags.length > 0 && (
          <div class="post-tags">
            {post.data.tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </div>

      <div class="post-body">
        <Content />
      </div>

      <div class="divider"></div>

      <div class="post-footer">
        <p class="post-footer-note">
          <em>This entry was found in the ledger of the Crossroads Inn.
          The keeper neither confirms nor denies its accuracy.</em>
        </p>
        <a href="/the-ledger" class="btn-text">More entries from the Ledger</a>
      </div>

    </div>
  </article>

</Layout>

<style>
  .post-header {
    margin-bottom: var(--sp-xxl);
  }

  .back-link {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    color: var(--text-muted);
    display: inline-block;
    margin-bottom: var(--sp-lg);
  }
  .back-link:hover { color: var(--accent); }

  .post-header time {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--text-muted);
    display: block;
    margin-bottom: var(--sp-sm);
  }

  .post-header h1 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    color: var(--accent);
    margin-bottom: var(--sp-md);
  }

  .post-tags {
    display: flex;
    gap: var(--sp-xs);
  }

  .tag {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent-soft);
    background: var(--hearth-shadow);
    padding: 2px 8px;
    border-radius: 4px;
  }

  .post-body {
    font-size: 1.05rem;
    line-height: 1.85;
    color: var(--text);
  }

  .post-body :global(p) {
    margin-bottom: var(--sp-lg);
  }

  .post-body :global(em) {
    color: var(--accent-soft);
  }

  .post-body :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: var(--sp-lg);
    color: var(--text-muted);
    font-style: italic;
    margin: var(--sp-xl) 0;
  }

  .post-footer {
    text-align: center;
  }

  .post-footer-note {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: var(--sp-lg);
  }
</style>
