---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import roomEmber from '../assets/illustrations/room-ember.png';
import roomNorthwatch from '../assets/illustrations/room-northwatch.png';
import roomLoft from '../assets/illustrations/room-loft.png';

const title = 'Our Rooms — The Crossroads Inn | Stay at The Crossroads';
const description = 'The inn keeps the rooms it needs. Some are easier to find than others. Here are a few you might be offered.';

const rooms = [
  {
    name: 'The Ember Room',
    image: roomEmber,
    alt: 'The Ember Room — warm light, stone fireplace, quilted bed in amber tones',
    price: '3 Gold Crowns',
    description: `The warmest room in the inn. A stone fireplace that never quite goes out.
      Quilts heavy enough to hold you down, in the good way. The walls are the color
      of late afternoon, and the window looks out over the kitchen garden where the
      rosemary grows taller than it should.`,
    details: 'Best for those who run cold. The fire adjusts itself to your mood — the keeper says it\'s the draft, but Henrick swears the embers watch you.',
  },
  {
    name: 'The Northwatch Room',
    image: roomNorthwatch,
    alt: 'The Northwatch Room — cool blue-grey stone, tall window overlooking northern roads',
    price: '4 Gold Crowns',
    description: `High-ceilinged. Cool stone. A window that faces the northern road, where the
      mountains go blue at dusk and the stars come out first. The bed is narrower here,
      tucked against the wall, with a writing desk that catches the morning light.`,
    details: 'Best for thinkers. Scholars. People who came here to figure something out. The room is quiet in a way that empty rooms aren\'t — it listens.',
  },
  {
    name: "The Dreamer's Loft",
    image: roomLoft,
    alt: "The Dreamer's Loft — exposed beams, skylights, dried herbs hanging from rafters",
    price: '5 Gold Crowns',
    description: `Up the narrow stairs, past the landing where the cat sleeps. Exposed beams.
      Skylights that frame the moon. Dried herbs hanging from the rafters — lavender,
      chamomile, something the keeper won't name. The bed is wide and low, covered in
      mismatched quilts.`,
    details: 'Best for those who need to sleep — really sleep. The kind of sleep where you dream true and wake up lighter. The loft remembers what you dream, though it keeps its own counsel.',
  },
];
---

<Layout title={title} description={description}>

  <section class="section container">
    <div class="content-narrow">
      <div class="page-header">
        <p class="eyebrow">Choose Your Rest</p>
        <h1>Our Rooms</h1>
        <p class="page-sub">
          The inn keeps the rooms it needs. Some you'll find. Some find you. Here are a few we can speak for.
        </p>
      </div>
    </div>
  </section>

  <section class="container">
    <div class="rooms-list">
      {rooms.map((room, i) => (
        <article class={`room-card ${i % 2 === 1 ? 'room-card--reverse' : ''}`}>
          <div class="room-image img-warm">
            <Image
              src={room.image}
              alt={room.alt}
              width="600" height="400"
              loading="lazy" decoding="async"
            />
          </div>
          <div class="room-content">
            <div class="room-price">{room.price} / night</div>
            <h2>{room.name}</h2>
            <p class="room-desc">{room.description}</p>
            <p class="room-details"><em>{room.details}</em></p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <div class="divider"></div>

  <section class="section container">
    <div class="content-narrow" style="text-align: center;">
      <div class="card rooms-note">
        <h3>A Note from the Keeper</h3>
        <p>
          The inn assigns rooms. You can ask, of course — the keeper is polite
          about it — but the building has opinions, and it's usually right.
          Trust the door that opens for you.
        </p>
        <p>
          If none of the rooms suit you, pull a chair up to the hearth.
          The fire is always lit. You're welcome to stay as long as you like.
        </p>
        <a href="/the-hearth" class="btn-text" style="margin-top: var(--sp-md); display: inline-flex;">Join the Hearth instead</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-header {
    text-align: center;
    margin-bottom: var(--sp-xl);
  }

  .eyebrow {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent-soft);
    margin-bottom: var(--sp-xs);
  }

  .page-sub {
    color: var(--text-muted);
    font-style: italic;
    max-width: 45ch;
    margin: 0 auto;
  }

  .rooms-list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-hero);
  }

  .room-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-xxl);
    align-items: center;
  }

  .room-card--reverse {
    direction: rtl;
  }
  .room-card--reverse > * {
    direction: ltr;
  }

  .room-image {
    aspect-ratio: 3 / 2;
  }

  .room-price {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-soft);
    margin-bottom: var(--sp-sm);
  }

  .room-content h2 {
    font-size: 1.8rem;
    margin-bottom: var(--sp-md);
  }

  .room-desc {
    color: var(--text);
    line-height: 1.8;
    margin-bottom: var(--sp-md);
  }

  .room-details {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .rooms-note {
    text-align: center;
    max-width: 540px;
    margin: 0 auto;
  }

  .rooms-note h3 {
    color: var(--accent);
    margin-bottom: var(--sp-md);
  }

  .rooms-note p {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .room-card,
    .room-card--reverse {
      grid-template-columns: 1fr;
      direction: ltr;
      gap: var(--sp-lg);
    }
    .rooms-list { gap: var(--sp-xxl); }
  }
</style>
