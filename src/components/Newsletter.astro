---
// MailerLite form — same account as jasonkrebsbooks.
// Account: 2271322, Form: 184855632701032232
// Posts directly to MailerLite's unauthenticated form-subscribe endpoint.
---

<div class="newsletter-card card">
  <h3>Sign the Guestbook</h3>
  <p class="newsletter-lead">
    Stories from the inn. Early looks at new chapters. The occasional secret
    slipped under your door.
  </p>
  <p class="newsletter-note">No spam. No schedule. Unsubscribe whenever.</p>

  <form
    id="newsletter-form"
    class="newsletter-form"
    action="https://assets.mailerlite.com/jsonp/2271322/forms/184855632701032232/subscribe"
    method="POST"
  >
    <label class="visually-hidden" for="newsletter-email">Email address</label>
    <input
      id="newsletter-email"
      type="email"
      name="fields[email]"
      placeholder="your@email.com"
      autocomplete="email"
      required
    />
    <input type="hidden" name="ml-submit" value="1" />
    <input type="hidden" name="anticsrf" value="true" />
    <button type="submit" class="btn-primary">Sign the Book</button>
  </form>
  <p id="newsletter-message" class="newsletter-message" aria-live="polite"></p>
</div>

<style>
  .newsletter-card {
    text-align: center;
    max-width: 540px;
    margin: 0 auto;
  }

  .newsletter-card h3 {
    font-family: var(--font-heading);
    color: var(--accent);
    font-size: 1.5rem;
    margin-bottom: var(--sp-sm);
  }

  .newsletter-lead {
    color: var(--text);
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: var(--sp-sm);
  }

  .newsletter-note {
    color: var(--text-muted);
    font-size: 0.85rem;
    font-style: italic;
    margin-bottom: var(--sp-lg);
  }

  .newsletter-form {
    display: flex;
    gap: var(--sp-sm);
    flex-wrap: wrap;
    justify-content: center;
  }

  .newsletter-form input[type="email"] {
    flex: 1 1 14rem;
    padding: 0.85rem 1rem;
    background: var(--hearth-shadow);
    border: 1px solid var(--worn-wood);
    border-radius: var(--radius);
    color: var(--text);
    font-family: var(--font-body);
    font-size: 1rem;
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  .newsletter-form input[type="email"]::placeholder {
    color: var(--aged-cream);
    opacity: 0.6;
  }

  .newsletter-form input[type="email"]:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(200, 155, 94, 0.2);
  }

  .newsletter-message {
    margin-top: var(--sp-md);
    font-size: 0.9rem;
    min-height: 1.2rem;
    color: var(--text-muted);
  }
  .newsletter-message.success { color: var(--accent); font-weight: 600; }
  .newsletter-message.error { color: #c47070; }

  .visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap; border: 0;
  }
</style>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
  const msg = document.getElementById('newsletter-message');

  if (form && msg) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const emailInput = form.querySelector<HTMLInputElement>('input[type="email"]');
      const email = emailInput?.value?.trim();
      if (!email) return;

      msg.textContent = 'Signing…';
      msg.className = 'newsletter-message';

      try {
        const body = new URLSearchParams();
        body.set('fields[email]', email);
        body.set('ml-submit', '1');
        body.set('anticsrf', 'true');

        await fetch(form.action, {
          method: 'POST',
          mode: 'no-cors',
          body,
        });

        msg.textContent = 'Signed. Welcome to the inn — check your email.';
        msg.className = 'newsletter-message success';
        form.reset();
      } catch {
        msg.textContent = 'Something went wrong. Try again in a moment.';
        msg.className = 'newsletter-message error';
      }
    });
  }
</script>
