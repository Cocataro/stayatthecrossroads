---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import bookCover from '../assets/illustrations/book-cover.png';

const title = "The Keeper's Reluctance — The Crossroads Inn, Book 1 | Stay at The Crossroads";
const description = "The battlefield has no place for broken things. The first book of The Crossroads Inn — a Heartland Fantasy series by Jason Krebs about a battlefield commander who walked away, the inn that found her, and something older waking in the walls.";
---

<Layout title={title} description={description}>

  <section class="section container">
    <div class="content-narrow">

      <div class="page-header">
        <p class="eyebrow">The Crossroads Inn Series</p>
        <h1>Stay the Night</h1>
        <p class="page-sub">Six books. One inn. Every road leads back.</p>
      </div>

    </div>
  </section>

  <!-- ═══ BOOK ONE FEATURE ═══ -->
  <section class="section-sm container">
    <div class="book-feature">
      <div class="book-cover img-warm">
        <Image
          src={bookCover}
          alt="The Crossroads Inn — Book One cover"
          width="600" height="900"
          loading="eager" decoding="async"
          fetchpriority="high"
        />
      </div>
      <div class="book-detail">
        <p class="eyebrow">Book One</p>
        <h2>The Keeper's Reluctance</h2>
        <p class="book-subtitle">The Crossroads Inn, Book 1</p>

        <p class="book-hook">
          The battlefield has no place for broken things.
        </p>

        <p>
          Briar Thornheart said it to her own soldiers the day she dismissed
          them, after the magic at Ashen Reach took her sword arm and eleven of
          her command. She meant it as a kindness. She knew it was a lie.
        </p>
        <p>
          Six months later, with five coins and no plan, she signs a deed for
          an inn she didn't know existed — at a crossroads where five realms
          touch, run by a man who watched her from the upper window before she
          ever knocked. The fire was already burning. The bed was already made.
        </p>
        <p>
          The Crossroads Inn doesn't look for warriors. It looks for the ones
          who walked away.
        </p>
        <p>
          And something in its foundation is starting to wake.
        </p>

        <div class="book-ctas">
          <a href="/the-hearth" class="btn-primary">Get the First 3 Chapters</a>
          <a href="/the-prologue" class="btn-text">Read the Prologue</a>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ═══ SAMPLE CHAPTER ═══ -->
  <section id="sample" class="section container">
    <div class="content-narrow">
      <h2 style="text-align: center;">Read the Opening</h2>
      <p class="section-sub" style="text-align: center;">The Prologue is up at <a href="/the-prologue">The Prologue</a>. Chapter One arrives in your inbox when you join the Hearth.</p>

      <div class="sample-chapter card">
        <h3>Chapter One: The Unusual Day</h3>
        <p class="sample-note">
          <em>Sign up at <a href="/the-hearth">The Hearth</a> and the first
          three chapters arrive in your inbox — free, no strings.</em>
        </p>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ═══ SERIES OVERVIEW ═══ -->
  <section class="section container">
    <div class="content-narrow" style="text-align: center;">
      <h2>The Series</h2>
      <p class="section-sub">Six books planned. One inn. Many roads.</p>

      <div class="series-grid">
        <div class="card series-card current">
          <span class="series-badge">Book 1</span>
          <h3>The Keeper's Reluctance</h3>
          <p>Coming soon</p>
        </div>
        <div class="card series-card">
          <span class="series-badge">Book 2</span>
          <h3>Doors Between Realms</h3>
          <p>In development</p>
        </div>
        <div class="card series-card">
          <span class="series-badge">Book 3</span>
          <h3>Echoes of Old Keepers</h3>
          <p>Outlined</p>
        </div>
        <div class="card series-card">
          <span class="series-badge">Book 4</span>
          <h3>Heartfire Ascendant</h3>
          <p>Outlined</p>
        </div>
        <div class="card series-card">
          <span class="series-badge">Book 5</span>
          <h3>Shadow in the Crossroads</h3>
          <p>Outlined</p>
        </div>
        <div class="card series-card">
          <span class="series-badge">Book 6</span>
          <h3>Keeper's Dawn</h3>
          <p>Outlined</p>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-header {
    text-align: center;
    margin-bottom: var(--sp-xl);
  }

  .eyebrow {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent-soft);
    margin-bottom: var(--sp-xs);
  }

  .page-sub, .section-sub {
    color: var(--text-muted);
    font-style: italic;
    margin-bottom: var(--sp-lg);
  }

  /* ═══ BOOK FEATURE ═══ */
  .book-feature {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: var(--sp-xxl);
    align-items: start;
  }

  .book-cover { max-width: 300px; }
  .book-cover img {
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  .book-subtitle {
    font-family: var(--font-ui);
    font-style: italic;
    font-size: 1rem;
    color: var(--text-muted);
    margin-bottom: var(--sp-lg);
  }

  .book-hook {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1.3rem;
    color: var(--accent);
    line-height: 1.4;
    margin-bottom: var(--sp-lg);
    padding-left: var(--sp-lg);
    border-left: 3px solid var(--accent);
  }

  .book-detail p {
    color: var(--text-muted);
    margin-bottom: var(--sp-md);
  }

  .comp-titles {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    color: var(--aged-cream);
    margin-top: var(--sp-lg);
  }

  .book-ctas {
    display: flex;
    gap: var(--sp-lg);
    align-items: center;
    margin-top: var(--sp-xl);
    flex-wrap: wrap;
  }

  /* ═══ SAMPLE CHAPTER ═══ */
  .sample-chapter {
    margin-top: var(--sp-xl);
    padding: var(--sp-xl);
  }

  .sample-chapter h3 {
    color: var(--accent);
    margin-bottom: var(--sp-md);
  }

  .sample-note {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  /* ═══ SERIES GRID ═══ */
  .series-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: var(--sp-md);
    margin-top: var(--sp-xl);
  }

  .series-card {
    text-align: center;
    padding: var(--sp-lg);
  }

  .series-badge {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-soft);
  }

  .series-card h3 {
    font-size: 1rem;
    margin: var(--sp-sm) 0 var(--sp-xs);
  }

  .series-card p {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .series-card.current {
    border: 1px solid var(--accent);
  }

  @media (max-width: 768px) {
    .book-feature {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .book-cover {
      margin: 0 auto;
      max-width: 220px;
    }
    .book-hook {
      border-left: none;
      padding-left: 0;
      text-align: center;
    }
    .book-ctas { justify-content: center; }
  }
</style>
